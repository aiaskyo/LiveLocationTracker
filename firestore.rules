rules_version = '2';

// Deploy with: firebase deploy --only firestore:rules
// (requires the Firebase CLI and a firebase.json pointing at this file)
service cloud.firestore {
  match /databases/{database}/documents {

    // live_locations/{userId}  ->  a single "current position" doc per user.
    // Only the authenticated owner may write their own location. Adjust the
    // read rule if you want other authenticated users (e.g. friends/family
    // in a sharing group) to be able to view a given user's live position.
    match /live_locations/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;

      // live_locations/{userId}/location_history/{entryId} -> append-only log
      match /location_history/{entryId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null && request.auth.uid == userId;
        allow update, delete: if false; // history is immutable
      }
    }
  }
}
